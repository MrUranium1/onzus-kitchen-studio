{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A menu item product information",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "img": { "type": "string", "format": "uri" },
        "category": { "type": "string" },
        "shortDescription": { "type": "string" },
        "longDescription": { "type": "string" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "ribbon": { "type": "string" }
      },
      "required": ["id", "name", "price", "img", "category", "shortDescription", "longDescription", "rating", "reviews"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order information",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "location", "status", "createdAt"]
    },
    "HomeCuration": {
      "title": "HomeCuration",
      "description": "Featured banners for home page",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "imageUrl", "order"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Customer inquiry or message",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "adminReply": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "replied"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "repliedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email", "subject", "message", "status", "createdAt"]
    },
    "Address": {
      "title": "Address",
      "description": "User saved address",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string", "enum": ["Home", "Work", "Other"] },
        "fullAddress": { "type": "string" },
        "landmark": { "type": "string" },
        "isDefault": { "type": "boolean" }
      },
      "required": ["id", "label", "fullAddress", "isDefault"]
    },
    "OTP": {
      "title": "OTP",
      "description": "Temporary verification code",
      "type": "object",
      "properties": {
        "otp": { "type": "string" },
        "expiresAt": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["otp", "expiresAt"]
    }
  },
  "firestore": {
    "/otps/{email}": {
      "schema": "OTP",
      "description": "Stores temporary 6-digit OTP codes for email verification."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all menu items"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "/users/{userId}/addresses/{addressId}": {
      "schema": "Address",
      "description": "Subcollection of user saved addresses"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "/home_curation/{itemId}": {
      "schema": "HomeCuration",
      "description": "Collection of featured homepage content"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of customer inquiries"
    },
    "/admins/{adminId}": {
      "schema": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" }
        },
        "required": ["email"]
      },
      "description": "Collection of admin user UIDs"
    }
  }
}
