rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email.lower() in ['hossainmehir2006@gmail.com', 'onzu080@gmail.com']
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Product Validation ---
    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'price', 'img', 'category', 'shortDescription', 'longDescription', 'rating', 'reviews'])
        && (data.id is number || data.id is string)
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.price is number && data.price >= 0
        && data.img is string && data.img.size() <= 500
        && data.category is string && data.category.size() <= 100
        && data.shortDescription is string && data.shortDescription.size() <= 500
        && data.longDescription is string && data.longDescription.size() <= 5000
        && data.rating is number && data.rating >= 0 && data.rating <= 5
        && data.reviews is number && data.reviews >= 0
        && (!data.keys().hasAny(['ribbon']) || data.ribbon is string)
        && (!data.keys().hasAny(['featured']) || data.featured is bool)
        && (!data.keys().hasAny(['featuredOrder']) || data.featuredOrder is number);
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt'])
        && data.uid == request.auth.uid
        && data.email == request.auth.token.email.lower()
        && data.role in ['user', 'admin']
        && (data.createdAt is timestamp || data.createdAt is string)
        && (!data.keys().hasAny(['name']) || data.name is string)
        && (!data.keys().hasAny(['phoneNumber']) || data.phoneNumber is string)
        && (!data.keys().hasAny(['address']) || data.address is string)
        && (!data.keys().hasAny(['photoURL']) || data.photoURL is string)
        && (!data.keys().hasAny(['updatedAt']) || data.updatedAt is timestamp || data.updatedAt is string);
    }

    function isValidAddress(data) {
      return data.keys().hasAll(['label', 'fullAddress', 'isDefault'])
        && data.label in ['Home', 'Work', 'Other']
        && data.fullAddress is string && data.fullAddress.size() > 0 && data.fullAddress.size() <= 2000
        && data.isDefault is bool
        && (!data.keys().hasAny(['id']) || data.id is string)
        && (!data.keys().hasAny(['landmark']) || data.landmark is string)
        && (!data.keys().hasAny(['createdAt']) || data.createdAt is timestamp || data.createdAt is string);
    }

    // --- Order Validation ---
    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'totalAmount', 'location', 'status', 'createdAt'])
        && (data.userId == request.auth.uid || isAdmin())
        && data.items is list
        && data.totalAmount is number && data.totalAmount >= 0
        && data.location is string && data.location.size() <= 2000
        && data.status in ['pending', 'preparing', 'ready', 'delivered', 'cancelled']
        && (data.createdAt is timestamp || data.createdAt is string);
    }

    // --- Curation Validation ---
    function isValidCuration(data) {
      return data.keys().hasAll(['id', 'imageUrl', 'order'])
        && data.id is string
        && data.imageUrl is string && data.imageUrl.size() <= 1000
        && data.order is number
        && (!data.keys().hasAny(['title']) || data.title is string)
        && (!data.keys().hasAny(['subtitle']) || data.subtitle is string);
    }

    // --- Inquiry Validation ---
    function isValidInquiry(data) {
      return data.keys().hasAll(['userId', 'name', 'email', 'subject', 'message', 'status', 'createdAt'])
        && (data.userId == (resource != null ? existing().userId : request.auth.uid) || data.userId == 'guest' || isAdmin())
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.subject is string && data.subject.size() > 0 && data.subject.size() <= 200
        && data.message is string && data.message.size() > 0 && data.message.size() <= 5000
        && data.status in ['pending', 'replied']
        && (data.createdAt is timestamp || data.createdAt is string)
        && (!data.keys().hasAny(['phone']) || data.phone is string)
        && (!data.keys().hasAny(['adminReply']) || data.adminReply is string)
        && (!data.keys().hasAny(['repliedAt']) || data.repliedAt is timestamp || data.repliedAt is string);
    }

    // --- Rules ---

    match /home_curation/{itemId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(itemId) && isValidCuration(incoming());
      allow update: if isAdmin() && isValidCuration(incoming());
      allow delete: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if (isSignedIn() || (incoming().userId == 'guest')) && isValidId(inquiryId) && isValidInquiry(incoming());
      allow update: if isAdmin() && isValidInquiry(incoming()) && (
        incoming().status == 'replied' &&
        incoming().diff(existing()).affectedKeys().hasOnly(['adminReply', 'status', 'repliedAt'])
      );
      allow delete: if isAdmin();
    }

    match /otps/{email} {
      allow read, write: if false; // Only server-side access via Admin SDK
    }

    match /products/{productId} {
      allow read: if true; // Publicly readable menu
      
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      
      allow update: if isAdmin() && isValidProduct(incoming()); // Simplified admin update
      
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && isValidId(orderId) && isValidOrder(incoming());
      allow update: if isAdmin() && (
        // For status updates, we just need to ensure the status is valid
        incoming().status in ['pending', 'preparing', 'ready', 'delivered', 'cancelled'] &&
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      );
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get, list: if isSignedIn() && (isOwner(userId) || isAdmin());
      
      allow create: if isOwner(userId) && incoming().role == 'user';
      
      allow update: if isOwner(userId) && (
        incoming().role == (existing().keys().hasAny(['role']) ? existing().role : 'user')
      );
        
      allow delete: if isOwner(userId) || isAdmin();

      match /addresses/{addressId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidAddress(incoming());
        allow delete: if isOwner(userId);
      }
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isOwner(adminId) && request.auth.token.email.lower() in ['hossainmehir2006@gmail.com', 'onzu080@gmail.com'];
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
